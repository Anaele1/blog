  <script>
  // Store references to the elements for cleaner code
        const navMenuButton = document.getElementById("navMenu");
        const navShowElement = document.getElementById("navShow");

        // Function to show the navigation menu
        const showNav = (event) => {
            // Stop the event from "bubbling up" to the bodys click listener
            event.stopPropagation(); 
            navShowElement.style.display = "block";
        };

        // Function to hide the navigation menu
        const hideNav = () => {
            navShowElement.style.display = "none";
        };

        // Add event listener to the button to show the menu
        navMenuButton.addEventListener("click", showNav);

        // Add event listener to the entire body to hide the menu
        // document.body.addEventListener("click", hideNav);
          
         // Add event listener to hide the menu
        document.getElementById('close').addEventListener("click", hideNav);


        // Optional: Also hide the nav if a link *within* the nav is clicked
        const navLinks = document.querySelectorAll('.list');
        navLinks.forEach(link => {
            link.addEventListener('click', hideNav);
        });

  
  </script>
  
<!-- Responsive navigation script-->
<script>
/* Toggle between adding and removing the "responsive" class to topnav when the user clicks on the icon */
function myFunction() {
  var x = document.getElementById("myTopnav");
  if (x.className === "topnav") {
    x.className += " responsive";
  } else {
    x.className = "topnav";
  }
}
</script>