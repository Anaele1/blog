<!-- Address script -->
<script>
  const AddressOpen = document.getElementById('addressOpen');
  const AddressForm = document.getElementById('addressForm');
  const CloseAddressForm = document.getElementById('clsAddressForm');

  AddressOpen.addEventListener('click', () => {
    AddressForm.style.display = "block";
    AddressOpen.style.borderBottom = "0.3px solid brown";
    CloseAddressForm.style.display = "block";
  });

  CloseAddressForm.addEventListener('click', () => {
    AddressForm.style.display = "none";
    AddressOpen.style.borderBottom = "none";
    CloseAddressForm.style.display = "none";
  });
</script>

<!-- Edit Script -->
<script>
  function activateField(fieldName) {
    const field = document.querySelector(`[name="${fieldName}"]`);
    const editSpan = field.nextElementSibling;
    const actionsDiv = document.getElementById(`${fieldName}Actions`);

    field.removeAttribute('readonly');
    field.focus();
    editSpan.classList.add('hidden');
    actionsDiv.classList.remove('hidden');
  }

  function cancelEdit(fieldName) {
    const field = document.querySelector(`[name="${fieldName}"]`);
    const editSpan = field.nextElementSibling;
    const actionsDiv = document.getElementById(`${fieldName}Actions`);

    field.setAttribute('readonly', 'readonly');
    editSpan.classList.remove('hidden');
    actionsDiv.classList.add('hidden');
  }
</script>