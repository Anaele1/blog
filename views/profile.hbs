  <!-- Profile picture script -->
  <script>
  const fileInput = document.getElementById('profilePicInput');
  const uploadButton = document.getElementById('picUpload');
  const picOpen = document.getElementById('picOpen');
  const picForm = document.getElementById('picForm');
  const picClose = document.getElementById('picClose');

  fileInput.addEventListener('change', function() {
    if (this.files.length > 0) {
      uploadButton.style.display = 'block';
    } else {
      uploadButton.style.display = 'none';
    }
  });

  picOpen.addEventListener('click', function() {
    picForm.style.display = 'block';
  });

  picClose.addEventListener('click', function(e) {
    e.preventDefault();
    picForm.style.display = 'none';
  });
</script>
  
  
  <!-- Bio update Script -->
  <script>
  const nameInput = document.querySelector('input[name="name"]');
  const addressInput = document.querySelector('input[name="address"]');
  const submitBtn = document.getElementById('submitBtn');


  function checkFocus() {
    if (document.activeElement === nameInput || document.activeElement === addressInput) {
      submitBtn.style.display = 'block';
    } else {
      submitBtn.style.display = 'none';
    }
  }

  nameInput.addEventListener('focus', checkFocus);
  addressInput.addEventListener('focus', checkFocus);
  nameInput.addEventListener('blur', checkFocus);
  addressInput.addEventListener('blur', checkFocus);
  
  
</script>
  
  <!-- Profile picture upload script -->
  <script>
     profilePicOpen = document.getElementById('picOpen');
     profilePicForm = document.getElementById('picForm');
     profilePicClose = document.getElementById('picClose');
  
     profilePicOpen.addEventListener('click', () => {
       profilePicForm.style.display = 'block';
       profilePicClose.style.display = 'block';
     });
  
     profilePicClose.addEventListener('click', () => {
       profilePicForm.style.display = 'none';
       profilePicClose.style.display = 'none';
     });
  
  </script>

  <!-- Delete account script --> 
  <script>
     deleteOpen = document.getElementById('accountDeleteOpen');
     deleteReady = document.getElementById('showAccountDelete');
     CloseDelete = document.getElementById('closeDelete');
     
     deleteOpen.addEventListener('click', () => {
       deleteReady.style.display = 'block';
     });

     CloseDelete.addEventListener('click', () => {
       deleteReady.style.display = 'none';
     });
  </script>

  <!-- Password change script -->
  <script>
  OpenPswChange = document.getElementById('pswOpen');
  PswChangeShow = document.getElementById('pswChange');
  ClosePswChange = document.getElementById('pswClose');

function PswOpen() {
    PswChangeShow.style.display = 'block';
    ClosePswChange.style.display = 'block';
}

function PswClose() {
    PswChangeShow.style.display = 'none';
    ClosePswChange.style.display = 'none';
}
