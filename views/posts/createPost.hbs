 <style>
    body {
      font-family: Arial, sans-serif;
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }
    .form-group {
      margin-bottom: 15px;
      position: relative;
    }
    label {
      display: block;
      margin-bottom: 5px;
      font-weight: bold;
    }
    input[type="text"],
    textarea {
      width: 100%;
      padding: 8px;
      border: 1px solid #ddd;
      border-radius: 4px;
      box-sizing: border-box;
    }
    textarea {
      min-height: 100px;
      resize: vertical;
    }
    .edit-span {
       /* MAKING IT APPEAR TOP */
      /* position: absolute;
      right: 10px;
      top: 0; */
      color: blue;
      cursor: pointer;
      user-select: none;
    }
    .field-actions {
      /* MAKING IT APPEAR TOP */
      /*position: absolute;
      right: 0;
      top: 0; */
      display: none;
    }
    .field-actions button {
      margin-left: 5px;
      padding: 3px 8px;
      font-size: 12px;
      cursor: pointer;
    }
    .form-actions {
      margin-top: 20px;
      text-align: right;
    }
    .form-actions button {
      margin-left: 10px;
      padding: 8px 15px;
      cursor: pointer;
    }
    input:read-only,
    textarea:read-only {
      background-color: #f9f9f9;
      cursor: not-allowed;
    }
  
  .element { 
    background: green;
    text-align: center;
  border-radius: 25px;
  corner-shape: bevel round scoop squircle; /* superellipse(0);  equal to 'bevel' */
}
  
  .product-badge {
  border-radius: 0 4px 4px 0;
  background-color: var(--badge-bg);
}
  
  @layer demo {
  @supports (corner-shape: bevel) {
    .primary {
      corner-shape: bevel;
      transition: corner-shape 0.3s ease;

      &:hover {
        corner-shape: squircle;
      }
    }

    .secondary {
      border-radius: 25px;
      corner-shape: superellipse(0.5);
    }

    .danger {
      border-radius: 16px;
      corner-shape: squircle;
    }

    .notch {
      border-radius: 12px;
      corner-shape: notch;
    }

    .scoop {
      border-radius: 14px;
      corner-shape: scoop;
    }
  }
}



  </style>

