{{> writersNavs}}

<form id="postForm" action="/api/post/create-post" method="POST">
    <input type="hidden" value="{{user.id}}" name="writerId" required>

    <div class="form-group">
      <label for="title">Title</label>
      <input type="text" name="title" placeholder="Give your post a title" readonly>
      <span class="edit-span" onclick="activateField(this)">Edit</span>
      <div class="field-actions">
        <button type="button" class="save-btn" onclick="saveField(this)">Save</button>
        <button type="button" class="cancel-btn" onclick="cancelField(this)">Cancel</button>
      </div>
    </div>

    <div class="form-group">
      <label for="keywords">Keywords</label>
      <input type="text" name="keywrds" placeholder="Enter keywords in your post" readonly>
      <span class="edit-span" onclick="activateField(this)">Edit</span>
      <div class="field-actions">
        <button type="button" class="save-btn" onclick="saveField(this)">Save</button>
        <button type="button" class="cancel-btn" onclick="cancelField(this)">Cancel</button>
      </div>
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea name="description" placeholder="Write little description of your post" readonly></textarea>
      <span class="edit-span" onclick="activateField(this)">Edit</span>
      <div class="field-actions">
        <button type="button" class="save-btn" onclick="saveField(this)">Save</button>
        <button type="button" class="cancel-btn" onclick="cancelField(this)">Cancel</button>
      </div>
    </div>
    
    
    <div class="form-group">
      <label for="content">Content</label>
      <textarea id="content" name="content" placeholder="Post body" readonly></textarea>
      <span class="edit-span" onclick="activateField(this)">Edit</span>
      <div class="field-actions">
        <button type="button" class="save-btn" onclick="saveField(this)">Save</button>
        <button type="button" class="cancel-btn" onclick="cancelField(this)">Cancel</button>
      </div>
    </div>

    <div class="form-group">
      <label for="summary">Summary</label>
      <textarea name="summary" placeholder="Summarize your post" readonly></textarea>
      <span class="edit-span" onclick="activateField(this)">Edit</span>
      <div class="field-actions">
        <button type="button" class="save-btn" onclick="saveField(this)">Save</button>
        <button type="button" class="cancel-btn" onclick="cancelField(this)">Cancel</button>
      </div>
    </div>

    <div class="form-actions">
      <button type="button" class="cancel-all">Cancel</button>
      <button type="button" class="save-all">Save</button>
      <button type="submit">Create Post</button>
    </div>
</form>

  <script>
    function activateField(editSpan) {
      const group = editSpan.parentElement;
      const input = group.querySelector('input, textarea');
      const actions = group.querySelector('.field-actions');
      const editSpanElement = group.querySelector('.edit-span');

      input.readOnly = false;
      input.focus();
      editSpanElement.style.display = 'none';
      actions.style.display = 'block';
    }

    function saveField(saveBtn) {
      const group = saveBtn.parentElement.parentElement;
      const input = group.querySelector('input, textarea');
      const editSpanElement = group.querySelector('.edit-span');
      const actions = group.querySelector('.field-actions');

      input.readOnly = true;
      editSpanElement.style.display = 'block';
      actions.style.display = 'none';
    }

    function cancelField(cancelBtn) {
      const group = cancelBtn.parentElement.parentElement;
      const input = group.querySelector('input, textarea');
      const editSpanElement = group.querySelector('.edit-span');
      const actions = group.querySelector('.field-actions');

      input.value = input.defaultValue;
      input.readOnly = true;
      editSpanElement.style.display = 'block';
      actions.style.display = 'none';
    }

    document.querySelector('.save-all').addEventListener('click', function() {
      document.querySelectorAll('input, textarea').forEach(input => {
        input.readOnly = true;
      });
      document.querySelectorAll('.edit-span').forEach(span => {
        span.style.display = 'block';
      });
      document.querySelectorAll('.field-actions').forEach(div => {
        div.style.display = 'none';
      });
    });

    document.querySelector('.cancel-all').addEventListener('click', function() {
      document.querySelectorAll('input, textarea').forEach(input => {
        input.value = input.defaultValue;
        input.readOnly = true;
      });
      document.querySelectorAll('.edit-span').forEach(span => {
        span.style.display = 'block';
      });
      document.querySelectorAll('.field-actions').forEach(div => {
        div.style.display = 'none';
      });
    });
  </script>
